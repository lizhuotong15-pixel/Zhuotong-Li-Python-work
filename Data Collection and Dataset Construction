    "    \"form\", \"volume\", \"mass\", \"massing\", \"geometry\", \"geometric\",\n",
    "    \"facade\", \"façade\", \"elevation\", \"section\", \"plan\", \"structure\",\n",
    "    \"frame\", \"grid\", \"slab\", \"tower\", \"block\", \"plinth\", \"podium\",\n",
    "    \"cantilever\", \"column\", \"beam\", \"vault\", \"atrium\", \"courtyard\",\n",
    "    \"terrace\", \"roof\", \"skylight\", \"opening\", \"void\", \"solid\",\n",
    "    \"monolithic\", \"raw concrete\", \"exposed concrete\", \"concrete\",\n",
    "    \"textured\", \"ribbed\", \"angular\", \"rectilinear\", \"curved\",\n",
    "    \"sculptural\", \"staggered\", \"stepped\", \"layered\", \"carved\",\n",
    "    \"perforated\", \"screen\", \"wall\", \"walls\", \"ceiling\", \"monumental\"\n",
    "]\n",
    "\n",
    "FIELDNAMES = [\n",
    "    \"source_site\",\n",
    "    \"source_search_term\",\n",
    "    \"title\",\n",
    "    \"url\",\n",
    "    \"published_time\",\n",
    "    \"cover_image_url\",\n",
    "    \"cover_image_file\",\n",
    "    \"categories\",\n",
    "    \"tags\",\n",
    "    \"text\",\n",
    "    \"form_text\"\n",
    "]\n",
    "\n",
    "# =========================\n",
    "# 3. 通用函数\n",
    "# =========================\n",
    "def get_soup(url):\n",
    "    r = requests.get(url, headers=HEADERS, timeout=30)\n",
    "    r.raise_for_status()\n",
    "    return BeautifulSoup(r.text, \"lxml\")\n",
    "\n",
    "def meta(soup, prop=None, name=None):\n",
    "    if prop:\n",
    "        tag = soup.find(\"meta\", attrs={\"property\": prop})\n",
    "        return tag.get(\"content\", \"\") if tag else \"\"\n",
    "    if name:\n",
    "        tag = soup.find(\"meta\", attrs={\"name\": name})\n",
    "        return tag.get(\"content\", \"\") if tag else \"\"\n",
    "    return \"\"\n",
    "\n",
    "def safe_filename_from_url(url, fallback=\"image.jpg\"):\n",
    "    try:\n",
    "        path = urlparse(url).path\n",
    "        name = os.path.basename(path) or fallback\n",
    "        name = \"\".join(c for c in name if c.isalnum() or c in \"._-\")\n",
    "        if \".\" not in name:\n",
    "            name += \".jpg\"\n",
    "        return name[:120]\n",
    "    except Exception:\n",
    "        return fallback\n",
    "\n",
    "def download_image(img_url, prefix=\"\"):\n",
    "    if not img_url:\n",
    "        return \"\"\n",
    "\n",
    "    try:\n",
    "        r = requests.get(img_url, headers=HEADERS, timeout=30, stream=True)\n",
    "        r.raise_for_status()\n",
    "\n",
    "        fname = safe_filename_from_url(img_url)\n",
    "        if prefix:\n",
    "            fname = f\"{prefix}_{fname}\"\n",
    "\n",
    "        local_path = os.path.join(IMG_DIR, fname)\n",
    "\n",
    "        if os.path.exists(local_path) and os.path.getsize(local_path) > 0:\n",
    "            return local_path\n",
    "\n",
    "        with open(local_path, \"wb\") as f:\n",
    "            for chunk in r.iter_content(chunk_size=1024 * 64):\n",
    "                if chunk:\n",
    "                    f.write(chunk)\n",
    "\n",
    "        return local_path\n",
    "    except Exception as e:\n",
    "        print(\"Image download failed:\", img_url, e)\n",
    "        return \"\"\n",
    "\n",
    "def looks_like_block_page(soup):\n",
    "    title = soup.title.get_text(\" \", strip=True).lower() if soup.title else \"\"\n",
    "    text = soup.get_text(\" \", strip=True).lower()[:1200]\n",
    "    return (\"just a moment\" in title) or (\"enable javascript and cookies\" in text)\n",
    "\n",
    "def extract_form_text(paragraphs):\n",
    "    selected = []\n",
    "    for p in paragraphs:\n",
    "        p_lower = p.lower()\n",
    "        if any(keyword.lower() in p_lower for keyword in FORM_KEYWORDS):\n",
    "            selected.append(p)\n",
    "\n",
    "    if not selected:\n",
    "        selected = paragraphs[:6]\n",
    "\n",
    "    return \"\\n\".join(selected)\n",
    "\n",
    "# =========================\n",
    "# 4. Dezeen\n",
    "# =========================\n",
    "def dezeen_extract_paragraphs(soup):\n",
    "    article = soup.select_one(\"article.main-article\")\n",
    "    if not article:\n",
    "        return []\n",
    "\n",
    "    out = []\n",
    "    for p in article.find_all(\"p\"):\n",
    "        txt = p.get_text(\" \", strip=True)\n",
    "        if txt and \"Leave a comment\" not in txt:\n",
    "            out.append(txt)\n",
    "    return out\n",
    "\n",
    "def dezeen_extract_tags(article):\n",
    "    tags = []\n",
    "    if not article:\n",
    "        return tags\n",
    "\n",
    "    for a in article.select(\"a[href*='/tag/']\"):\n",
    "        txt = a.get_text(\" \", strip=True)\n",
    "        if txt:\n",
    "            tags.append(txt)\n",
    "\n",
    "    seen = set()\n",
    "    out = []\n",
    "    for x in tags:\n",
    "        if x not in seen:\n",
    "            out.append(x)\n",
    "            seen.add(x)\n",
    "    return out\n",
    "\n",
    "def dezeen_extract_categories(article):\n",
    "    if not article:\n",
    "        return []\n",
    "\n",
    "    out = []\n",
    "    for c in article.get(\"class\", []):\n",
    "        if c.startswith(\"category-\"):\n",
    "            out.append(c.replace(\"category-\", \"\"))\n",
    "\n",
    "    seen = set()\n",
    "    dedup = []\n",
    "    for x in out:\n",
    "        if x not in seen:\n",
    "            dedup.append(x)\n",
    "            seen.add(x)\n",
    "    return dedup\n",
    "\n",
    "def collect_dezeen_links(limit=3000, max_pages_per_term=20):\n",
    "    seen = set()\n",
    "    results = []\n",
    "\n",
    "    for term in DEZEEN_SEARCH_TERMS:\n",
    "        print(f\"\\nDezeen collecting: {term}\")\n",
    "\n",
    "        for page_num in range(1, max_pages_per_term + 1):\n",
    "            if page_num == 1:\n",
    "                url = f\"https://www.dezeen.com/search/{term}/\"\n",
    "            else:\n",
    "                url = f\"https://www.dezeen.com/search/{term}/page/{page_num}/\"\n",
    "\n",
    "            try:\n",
    "                soup = get_soup(url)\n",
    "            except Exception as e:\n",
    "                print(\"Dezeen search failed:\", url, e)\n",
    "                break\n",
    "\n",
    "            if looks_like_block_page(soup):\n",
    "                print(\"Dezeen blocked:\", url)\n",
    "                break\n",
    "\n",
    "            before_count = len(results)\n",
    "\n",
    "            for a in soup.find_all(\"a\", href=True):\n",
    "                href = a[\"href\"]\n",
    "                full_url = urljoin(url, href)\n",
    "\n",
    "                if \"dezeen.com\" not in full_url:\n",
    "                    continue\n",
    "                if \"/20\" not in full_url:\n",
    "                    continue\n",
    "                if full_url in seen:\n",
    "                    continue\n",
    "\n",
    "                seen.add(full_url)\n",
    "                results.append({\n",
    "                    \"source_site\": \"Dezeen\",\n",
    "                    \"source_search_term\": term,\n",
    "                    \"url\": full_url\n",
    "                })\n",
    "\n",
    "                if len(results) >= limit:\n",
    "                    return results\n",
    "\n",
    "            added = len(results) - before_count\n",
    "            print(f\"  page {page_num}: +{added}\")\n",
    "            if added == 0:\n",
    "                break\n",
    "\n",
    "            time.sleep(REQUEST_DELAY)\n",
    "\n",
    "    return results\n",
    "\n",
    "def parse_dezeen(item, index_num):\n",
    "    url = item[\"url\"]\n",
    "    soup = get_soup(url)\n",
    "\n",
    "    if looks_like_block_page(soup):\n",
    "        return None\n",
    "\n",
    "    article = soup.select_one(\"article.main-article\")\n",
    "    if not article:\n",
    "        return None\n",
    "\n",
    "    title = meta(soup, prop=\"og:title\")\n",
    "    published = meta(soup, prop=\"article:published_time\")\n",
    "    cover_image_url = meta(soup, prop=\"og:image\")\n",
    "    categories = dezeen_extract_categories(article)\n",
    "    tags = dezeen_extract_tags(article)\n",
    "    paragraphs = dezeen_extract_paragraphs(soup)\n",
    "\n",
    "    if not paragraphs:\n",
    "        return None\n",
    "\n",
    "    text = \"\\n\".join(paragraphs)\n",
    "    form_text = extract_form_text(paragraphs)\n",
    "    cover_file = download_image(cover_image_url, prefix=f\"D_{str(index_num).zfill(3)}\")\n",
    "\n",
    "    return {\n",
    "        \"source_site\": \"Dezeen\",\n",
    "        \"source_search_term\": item[\"source_search_term\"],\n",
    "        \"title\": title,\n",
    "        \"url\": url,\n",
    "        \"published_time\": published,\n",
    "        \"cover_image_url\": cover_image_url,\n",
    "        \"cover_image_file\": cover_file,\n",
    "        \"categories\": \", \".join(categories),\n",
    "        \"tags\": \", \".join(tags),\n",
    "        \"text\": text,\n",
    "        \"form_text\": form_text\n",
    "    }\n",
    "\n",
    "# =========================\n",
    "# 5. ArchDaily\n",
    "# =========================\n",
    "def archdaily_extract_paragraphs(soup):\n",
    "    paragraphs = []\n",
    "\n",
    "    containers = soup.select(\"div[itemprop='articleBody'], .post__content, .afd-post-content, article\")\n",
    "    for container in containers:\n",
    "        local = []\n",
    "        for p in container.find_all(\"p\"):\n",
    "            txt = p.get_text(\" \", strip=True)\n",
    "            if txt:\n",
    "                local.append(txt)\n",
    "        if len(local) >= 3:\n",
    "            return local\n",
    "\n",
    "    return paragraphs\n",
    "\n",
    "def archdaily_extract_tags(soup):\n",
    "    tags = []\n",
    "    for a in soup.select(\"a[href*='/tag/']\"):\n",
    "        txt = a.get_text(\" \", strip=True)\n",
    "        if txt:\n",
    "            tags.append(txt)\n",
    "\n",
    "    seen = set()\n",
    "    out = []\n",
    "    for x in tags:\n",
    "        if x not in seen:\n",
    "            out.append(x)\n",
    "            seen.add(x)\n",
    "    return out\n",
    "\n",
    "def archdaily_extract_categories(url, soup):\n",
    "    cats = []\n",
    "\n",
    "    body = soup.find(\"body\")\n",
    "    if body:\n",
    "        body_classes = body.get(\"class\", [])\n",
    "        for c in body_classes:\n",
    "            if \"architecture\" in c.lower():\n",
    "                cats.append(\"architecture\")\n",
    "\n",
    "    if \"/architecture/\" in url.lower():\n",
    "        cats.append(\"architecture\")\n",
    "\n",
    "    seen = set()\n",
    "    out = []\n",
    "    for x in cats:\n",
    "        if x not in seen:\n",
    "            out.append(x)\n",
    "            seen.add(x)\n",
    "    return out\n",
    "\n",
    "def collect_archdaily_links(limit=3000):\n",
    "    seen = set()\n",
    "    results = []\n",
    "\n",
    "    for tag_url in ARCHDAILY_TAG_URLS:\n",
    "        print(f\"\\nArchDaily collecting: {tag_url}\")\n",
    "\n",
    "        try:\n",
    "            soup = get_soup(tag_url)\n",
    "        except Exception as e:\n",
    "            print(\"ArchDaily tag failed:\", tag_url, e)\n",
    "            continue\n",
    "\n",
    "        for a in soup.find_all(\"a\", href=True):\n",
    "            href = a[\"href\"]\n",
    "            full_url = urljoin(tag_url, href)\n",
    "\n",
    "            if \"archdaily.com\" not in full_url:\n",
    "                continue\n",
    "            if \"/tag/\" in full_url:\n",
    "                continue\n",
    "            if \"/search/\" in full_url:\n",
    "                continue\n",
    "            if full_url in seen:\n",
    "                continue\n",
    "\n",
    "            # ArchDaily article URLs usually have numeric ids or long article paths\n",
    "            if not any(ch.isdigit() for ch in full_url):\n",
    "                continue\n",
    "\n",
    "            seen.add(full_url)\n",
    "            results.append({\n",
    "                \"source_site\": \"ArchDaily\",\n",
    "                \"source_search_term\": tag_url,\n",
    "                \"url\": full_url\n",
    "            })\n",
    "\n",
    "            if len(results) >= limit:\n",
    "                return results\n",
    "\n",
    "        time.sleep(REQUEST_DELAY)\n",
    "\n",
    "    return results\n",
    "\n",
    "def parse_archdaily(item, index_num):\n",
    "    url = item[\"url\"]\n",
    "    soup = get_soup(url)\n",
    "\n",
    "    title = meta(soup, prop=\"og:title\")\n",
    "    if not title:\n",
    "        h1 = soup.find(\"h1\")\n",
    "        title = h1.get_text(\" \", strip=True) if h1 else \"\"\n",
    "\n",
    "    published = meta(soup, prop=\"article:published_time\") or meta(soup, name=\"publish-date\")\n",
    "    cover_image_url = meta(soup, prop=\"og:image\")\n",
    "    categories = archdaily_extract_categories(url, soup)\n",
    "    tags = archdaily_extract_tags(soup)\n",
    "    paragraphs = archdaily_extract_paragraphs(soup)\n",
    "\n",
    "    if not paragraphs:\n",
    "        return None\n",
    "\n",
    "    text = \"\\n\".join(paragraphs)\n",
    "    form_text = extract_form_text(paragraphs)\n",
    "    cover_file = download_image(cover_image_url, prefix=f\"A_{str(index_num).zfill(3)}\")\n",
    "\n",
    "    return {\n",
    "        \"source_site\": \"ArchDaily\",\n",
    "        \"source_search_term\": item[\"source_search_term\"],\n",
    "        \"title\": title,\n",
    "        \"url\": url,\n",
    "        \"published_time\": published,\n",
    "        \"cover_image_url\": cover_image_url,\n",
    "        \"cover_image_file\": cover_file,\n",
    "        \"categories\": \", \".join(categories),\n",
    "        \"tags\": \", \".join(tags),\n",
    "        \"text\": text,\n",
    "        \"form_text\": form_text\n",
    "    }\n",
    "\n",
    "# =========================\n",
    "# 6. 主程序\n",
    "# =========================\n",
    "def main():\n",
    "    print(\"Collecting links...\")\n",
    "    dezeen_links = collect_dezeen_links(limit=2500, max_pages_per_term=20)\n",
    "    archdaily_links = collect_archdaily_links(limit=2500)\n",
    "\n",
    "    all_links = dezeen_links + archdaily_links\n",
    "    print(\"\\nTotal links collected:\", len(all_links))\n",
    "\n",
    "    rows = []\n",
    "    seen_urls = set()\n",
    "\n",
    "    for item in all_links:\n",
    "        url = item[\"url\"]\n",
    "\n",
    "        if url in seen_urls:\n",
    "            continue\n",
    "\n",
    "        try:\n",
    "            if item[\"source_site\"] == \"Dezeen\":\n",
    "                data = parse_dezeen(item, index_num=len(rows) + 1)\n",
    "            else:\n",
    "                data = parse_archdaily(item, index_num=len(rows) + 1)\n",
    "\n",
    "            if data:\n",
    "                rows.append(data)\n",
    "                seen_urls.add(url)\n",
    "                print(f\"[{len(rows)}] saved: {data['source_site']} | {data['title']}\")\n",
    "        except Exception as e:\n",
    "            print(\"fail:\", url, e)\n",
    "\n",
    "        time.sleep(REQUEST_DELAY)\n",
    "\n",
    "        if len(rows) >= MAX_ROWS:\n",
    "            break\n",
    "\n",
    "    with open(OUT_CSV, \"w\", newline=\"\", encoding=\"utf-8-sig\") as f:\n",
    "        writer = csv.DictWriter(f, fieldnames=FIELDNAMES)\n",
    "        writer.writeheader()\n",
    "        writer.writerows(rows)\n",
    "\n",
    "    print(\"\\nDONE ->\", OUT_CSV)\n",
    "    print(\"Images folder ->\", IMG_DIR)\n",
    "    print(\"Rows saved ->\", len(rows))\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  }
